# Copy to terraform.tfvars in this directory and fill in Alibaba Cloud-specific values.
# terraform.tfvars is gitignored; never commit secrets.

region       = "ap-southeast-1"
project_name = "campaign-center"
environment  = "dev"

# Single-AZ dev (default)
zones = ["ap-southeast-1a"]
vswitch_cidrs = {
  "ap-southeast-1a" = "10.10.1.0/24"
}

# Multi-AZ prod example (same region):
# zones = ["ap-southeast-1a", "ap-southeast-1b", "ap-southeast-1c"]
# vswitch_cidrs = {
#   "ap-southeast-1a" = "10.10.1.0/24"
#   "ap-southeast-1b" = "10.10.2.0/24"
#   "ap-southeast-1c" = "10.10.3.0/24"
# }
# master_count = 3

instance_type = "ecs.t6-c1m2.large"
image_id      = "ubuntu_22_04_x64_20G_alibase_20260522.vhd"
key_pair_name = "campaign-center-key"

# Optional — omit to use dev defaults (0.0.0.0/0). Set per location or use TF_VAR_* at apply time:
# allowed_ssh_cidr   = "203.0.113.10/32"
# allowed_admin_cidr = "203.0.113.10/32"

master_count = 1
worker_count = 0

vpc_cidr = "10.10.0.0/16"

system_disk_category          = "cloud_auto"
system_disk_size              = 60
system_disk_performance_level = ""

eip_attachment_mode = "ecs"
eip_bandwidth       = 5
create_eip          = false # set true after Alibaba Cloud real-name verification
