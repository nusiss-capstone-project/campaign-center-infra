# Example: private GitOps repository credentials (reference only — not applied by the role).
#
# When campaign-gitops becomes private:
#   1. Copy and edit this template locally (do not commit credentials)
#   2. kubectl apply -f /tmp/campaign-gitops-repo-secret.yaml
#
# Label required: argocd.argoproj.io/secret-type: repository
apiVersion: v1
kind: Secret
metadata:
  name: campaign-gitops-repo
  namespace: {{ argocd_namespace }}
  labels:
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  type: git
  url: {{ argocd_gitops_repo_url }}
  username: git
  password: "<github-personal-access-token>"
