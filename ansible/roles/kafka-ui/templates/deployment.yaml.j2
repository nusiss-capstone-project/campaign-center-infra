apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ kafka_ui_app_name }}
  namespace: {{ kafka_ui_namespace }}
  labels:
    app.kubernetes.io/name: {{ kafka_ui_app_name }}
    app.kubernetes.io/component: ui
    app.kubernetes.io/part-of: campaign-center-infra
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ kafka_ui_app_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ kafka_ui_app_name }}
        app.kubernetes.io/component: ui
    spec:
      containers:
        - name: kafka-ui
          image: {{ kafka_ui_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: {{ kafka_ui_service_port }}
          env:
            - name: KAFKA_CLUSTERS_0_NAME
              value: {{ kafka_ui_cluster_name | quote }}
            - name: KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS
              value: {{ kafka_ui_bootstrap_servers | quote }}
            - name: JAVA_OPTS
              value: {{ kafka_ui_java_opts | quote }}
          resources:
            requests:
              cpu: {{ kafka_ui_cpu_request }}
              memory: {{ kafka_ui_memory_request }}
            limits:
              cpu: {{ kafka_ui_cpu_limit }}
              memory: {{ kafka_ui_memory_limit }}
          startupProbe:
            httpGet:
              path: /actuator/health
              port: http
            periodSeconds: 10
            failureThreshold: 30
          readinessProbe:
            httpGet:
              path: /actuator/health
              port: http
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /actuator/health
              port: http
            initialDelaySeconds: 10
            periodSeconds: 20
