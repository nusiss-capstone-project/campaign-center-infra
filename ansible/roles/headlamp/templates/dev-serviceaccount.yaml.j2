apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ headlamp_dev_sa_name }}
  namespace: {{ headlamp_namespace }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: {{ headlamp_dev_sa_name }}-binding
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: {{ headlamp_dev_cluster_role }}
subjects:
  - kind: ServiceAccount
    name: {{ headlamp_dev_sa_name }}
    namespace: {{ headlamp_namespace }}
