apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ kafka_app_name }}
  namespace: {{ kafka_namespace }}
  labels:
    app.kubernetes.io/name: {{ kafka_app_name }}
    app.kubernetes.io/component: broker
spec:
  serviceName: {{ kafka_app_name }}-headless
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ kafka_app_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ kafka_app_name }}
        app.kubernetes.io/component: broker
    spec:
      terminationGracePeriodSeconds: 60
      securityContext:
        fsGroup: 1000
      containers:
        - name: kafka
          image: {{ kafka_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - name: plaintext
              containerPort: {{ kafka_client_port }}
            - name: controller
              containerPort: {{ kafka_controller_port }}
          env:
            - name: CLUSTER_ID
              value: {{ kafka_cluster_id | quote }}
            - name: KAFKA_NODE_ID
              value: "{{ kafka_node_id }}"
            - name: KAFKA_PROCESS_ROLES
              value: broker,controller
            - name: KAFKA_CONTROLLER_QUORUM_VOTERS
              value: >-
                {{ kafka_node_id }}@{{ kafka_app_name }}-0.{{ kafka_app_name }}-headless.{{ kafka_namespace }}.svc.cluster.local:{{ kafka_controller_port }}
            - name: KAFKA_LISTENERS
              value: >-
                PLAINTEXT://:{{ kafka_client_port }},CONTROLLER://:{{ kafka_controller_port }}
            - name: KAFKA_ADVERTISED_LISTENERS
              value: PLAINTEXT://{{ kafka_bootstrap }}
            - name: KAFKA_LISTENER_SECURITY_PROTOCOL_MAP
              value: CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
            - name: KAFKA_CONTROLLER_LISTENER_NAMES
              value: CONTROLLER
            - name: KAFKA_INTER_BROKER_LISTENER_NAME
              value: PLAINTEXT
            - name: KAFKA_LOG_DIRS
              value: {{ kafka_log_dirs }}
            - name: KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR
              value: "1"
            - name: KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR
              value: "1"
            - name: KAFKA_TRANSACTION_STATE_LOG_MIN_ISR
              value: "1"
            - name: KAFKA_DEFAULT_REPLICATION_FACTOR
              value: "1"
            - name: KAFKA_MIN_INSYNC_REPLICAS
              value: "1"
            - name: KAFKA_NUM_PARTITIONS
              value: "1"
            - name: KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS
              value: "0"
            - name: KAFKA_HEAP_OPTS
              value: {{ kafka_heap_opts | quote }}
          resources:
            requests:
              cpu: {{ kafka_cpu_request }}
              memory: {{ kafka_memory_request }}
            limits:
              cpu: {{ kafka_cpu_limit }}
              memory: {{ kafka_memory_limit }}
          volumeMounts:
            - name: data
              mountPath: {{ kafka_log_dirs }}
          startupProbe:
            tcpSocket:
              port: plaintext
            periodSeconds: 10
            failureThreshold: 30
          readinessProbe:
            tcpSocket:
              port: plaintext
            initialDelaySeconds: 10
            periodSeconds: 10
          livenessProbe:
            tcpSocket:
              port: plaintext
            initialDelaySeconds: 30
            periodSeconds: 20
  volumeClaimTemplates:
    - metadata:
        name: data
        labels:
          app.kubernetes.io/name: {{ kafka_app_name }}
      spec:
        accessModes:
          - ReadWriteOnce
        resources:
          requests:
            storage: {{ kafka_storage_size }}
